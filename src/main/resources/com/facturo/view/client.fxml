<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.facturo.controller.ClientController" spacing="10" style="-fx-padding: 20;">
    <Label text="Gestion des Clients" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="nameField" promptText="Nom" HBox.hgrow="ALWAYS"/>
        <TextField fx:id="addressField" promptText="Adresse" HBox.hgrow="ALWAYS"/>
        <TextField fx:id="phoneField" promptText="Téléphone" prefWidth="120"/>
        <TextField fx:id="emailField" promptText="Email" prefWidth="150"/>
        <Button text="Ajouter" onAction="#addClient" style="-fx-base: #4CAF50; -fx-text-fill: white;"/>
    </HBox>

    <TableView fx:id="clientTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colName" text="Nom" prefWidth="200"/>
            <TableColumn fx:id="colAddress" text="Adresse" prefWidth="250"/>
            <TableColumn fx:id="colPhone" text="Téléphone" prefWidth="120"/>
            <TableColumn fx:id="colEmail" text="Email" prefWidth="200"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Retour" onAction="#goBack"/>
    </HBox>
</VBox>
