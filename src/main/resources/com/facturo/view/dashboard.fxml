<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.Priority?>

<VBox xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.facturo.controller.DashboardController" spacing="20.0" alignment="CENTER" style="-fx-background-color: #f4f4f4;">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Facturo Dashboard" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>

    <HBox spacing="20.0" alignment="CENTER">
        <Button text="Créer Facture" onAction="#createInvoice" prefWidth="200.0" prefHeight="150.0" style="-fx-font-size: 18px; -fx-base: #4CAF50; -fx-text-fill: white;"/>
        <Button text="Historique" onAction="#viewHistory" prefWidth="200.0" prefHeight="150.0" style="-fx-font-size: 18px; -fx-base: #2196F3; -fx-text-fill: white;"/>
        <Button text="Clients" onAction="#manageClients" prefWidth="200.0" prefHeight="150.0" style="-fx-font-size: 18px; -fx-base: #FF9800; -fx-text-fill: white;"/>
    </HBox>
</VBox>
